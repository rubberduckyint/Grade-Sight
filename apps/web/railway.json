{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter web... build"
  },
  "deploy": {
    "startCommand": "pnpm --filter web start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
